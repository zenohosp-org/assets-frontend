# ─────────────────────────────────────────────────────────
# DEVELOPMENT ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────

# ── API Configuration ──
VITE_API_BASE_URL=http://localhost:8081
VITE_ASSET_BACKEND_URL=http://localhost:8081
VITE_DIRECTORY_API_URL=http://localhost:9000
VITE_API_TIMEOUT=30000

# ── Cookie Configuration (SHARED ACROSS ALL APPS) ──
# In development, use localhost for single domain
# In production, use .zenohosp.com for cross-domain SSO
VITE_COOKIE_DOMAIN=localhost
VITE_COOKIE_MAX_AGE=86400
VITE_COOKIE_SECURE=false

# ── SSO Configuration ──
# Redirect to Directory login page (SSO provider)
VITE_ACCOUNTS_LOGIN_URL=http://localhost:5173/login

# ── Application Configuration ──
VITE_APP_NAME=ZenoHosp Asset Manager
VITE_APP_ENVIRONMENT=development
